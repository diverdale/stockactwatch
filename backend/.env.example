# Backend env — used by FastAPI / Pydantic Settings
# Copy to .env and fill in your values

DATABASE_URL=postgresql+asyncpg://localhost/stock_tracker
QUIVER_API_KEY=your_quiver_api_key
FMP_API_KEY=your_fmp_api_key
INGEST_INTERVAL_MINUTES=15
AMENDMENT_RECHECK_DAYS=90
INTERNAL_SECRET=change_me_to_a_long_random_string
CONGRESS_API_KEY=your_congress_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
